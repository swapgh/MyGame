{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Gradle: Build",
            "type": "shell",
            "command": "${workspaceFolder}/gradlew",
            "args": [
                "build"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "build",
            "problemMatcher": [
                "$javac"
            ]
        },
        {
            "label": "Gradle: Clean",
            "type": "shell",
            "command": "${workspaceFolder}/gradlew",
            "args": [
                "clean"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": []
        },
        {
            "label": "Gradle: Projects",
            "type": "shell",
            "command": "${workspaceFolder}/gradlew",
            "args": [
                "projects"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": []
        },
        {
            "label": "Run Auth Server",
            "type": "shell",
            "command": "./tools/run-auth-server.sh",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": []
        },
        {
            "label": "Run World Server",
            "type": "shell",
            "command": "./tools/run-world-server.sh",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": []
        },
        {
            "label": "Run Client",
            "type": "shell",
            "command": "./tools/run-client.sh",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": []
        }
    ]
}
