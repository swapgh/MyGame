{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "java",
            "name": "WorldServerMain",
            "request": "launch",
            "mainClass": "com.game.server.world.app.WorldServerMain",
            "projectName": "server",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal"
        },
        {
            "type": "java",
            "name": "ClientMain",
            "request": "launch",
            "mainClass": "com.game.client.app.ClientMain",
            "projectName": "client",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "vmArgs": "--enable-native-access=ALL-UNNAMED"
        },
        {
            "type": "java",
            "name": "AuthServerMain",
            "request": "launch",
            "mainClass": "com.game.server.auth.app.AuthServerMain",
            "projectName": "server",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal"
        }
    ]
}
